@media (max-width: 768px) {
    nav ul {
        flex-direction: column;
        text-align: center;
    }

    nav li {
        margin: 10px 0;
    }

   .hero {
    display: flex;
    justify-content: space-around;
    align-items: center;
    }

    .hero-img {
        width: 300px;
    }

    .features {
        flex-direction: column;
        gap: 20px;
        text-align: center;
    }
}